# HermesNexus Cloud服务配置 - 本地演示环境

# 服务配置
CLOUD_API_HOST=127.0.0.1
CLOUD_API_PORT=8080
CLOUD_WORKERS=2

# 数据库配置
DB_TYPE=sqlite
SQLITE_DB_PATH=/Users/shengchun.sun/Library/CloudStorage/OneDrive-个人/MyCloud/Code/HermesNexus/local-deploy/data/hermesnexus.db

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=/Users/shengchun.sun/Library/CloudStorage/OneDrive-个人/MyCloud/Code/HermesNexus/local-deploy/logs

# 安全配置
JWT_SECRET=local-demo-secret-2026
API_AUTH_TOKEN=local-demo-token-2026

# 监控配置
ENABLE_METRICS=true
HEALTH_CHECK_INTERVAL=30