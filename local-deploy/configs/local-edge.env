# HermesNexus Edge节点配置 - 本地演示环境

# 节点配置
NODE_ID=local-edge-node-001
NODE_NAME=本地演示边缘节点
NODE_LOCATION=本地开发环境

# 服务端连接
CLOUD_API_URL=http://127.0.0.1:8080
REGISTRATION_INTERVAL=30
HEARTBEAT_INTERVAL=10

# 任务执行配置
TASK_POLL_INTERVAL=5
MAX_CONCURRENT_TASKS=2
TASK_TIMEOUT=300

# SSH配置
SSH_TIMEOUT=30
SSH_MAX_RETRIES=3

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=/Users/shengchun.sun/Library/CloudStorage/OneDrive-个人/MyCloud/Code/HermesNexus/local-deploy/logs