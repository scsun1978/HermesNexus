# HermesNexus 环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ===== 云端服务配置 =====
CLOUD_SERVICE_HOST=0.0.0.0
CLOUD_SERVICE_PORT=8080
CLOUD_API_PREFIX=/api/v1

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hermesnexus
DB_USER=hermes
DB_PASSWORD=change_me_in_production

# Redis 配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ===== 边缘节点配置 =====
EDGE_NODE_ID=edge-node-1
EDGE_NODE_NAME=Edge-Node-1
EDGE_HEARTBEAT_INTERVAL=30  # 心跳间隔(秒)

# 云端服务地址 (边缘节点连接云端)
CLOUD_SERVER_URL=http://localhost:8080
CLOUD_API_KEY=change_me_in_production

# ===== Hermes 相关配置 =====
# 项目专用的 Hermes 环境隔离
HERMES_HOME=.hermes
HERMES_VERSION=1.0.0
HERMES_LOG_LEVEL=INFO

# ===== 安全配置 =====
# JWT 密钥
JWT_SECRET=change_me_in_production_use_long_random_string
JWT_EXPIRATION_HOURS=24

# API 认证密钥
API_AUTH_TOKEN=change_me_in_production

# ===== 开发/调试配置 =====
# 开发模式
DEBUG=true
LOG_LEVEL=DEBUG

# 开发服务器配置
DEV_SERVER_HOST=172.16.100.101
DEV_SERVER_USER=scsun
DEV_SERVER_SSH_PORT=22

# ===== Docker 配置 =====
DOCKER_REGISTRY=localhost:5000
DOCKER_NETWORK=hermesnexus-network

# ===== 监控和观测 =====
# 启用 Metrics
ENABLE_METRICS=true
METRICS_PORT=9090

# 启用 Tracing
ENABLE_TRACING=false
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# ===== 前端配置 =====
CONSOLE_PORT=3000
CONSOLE_API_URL=http://localhost:8080

# ===== 任务执行配置 =====
# 任务超时时间(秒)
TASK_TIMEOUT=300

# 最大并发任务数
MAX_CONCURRENT_TASKS=10

# SSH 连接超时
SSH_TIMEOUT=30

# ===== 存储配置 =====
# 数据持久化路径
DATA_DIR=./data
LOG_DIR=./logs
UPLOAD_DIR=./uploads
