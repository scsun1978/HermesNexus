# HermesNexus Docker Build Ignore Files
# 优化Docker构建，排除不必要的文件

# Python相关
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境
venv/
.venv/
ENV/
env/
.ENV/

# IDE和编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 测试和覆盖率
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.cover
.hypothesis/

# 文档
docs/_build/
site/
*.md
!README.md

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# 数据库和日志
*.db
*.sqlite
*.sqlite3
*.log
logs/
data/

# 临时文件
tmp/
temp/
*.tmp
*.bak
*.swp

# Docker相关
Dockerfile*
docker-compose*.yml
.dockerignore

# 监控和运维
monitoring/
*.pid

# 开发工具配置
*.ini
.cfg
.envrc
.pre-commit-config.yaml

# 构建产物
build/
dist/
target/

# 备份文件
*.backup
*.old

# Node.js (如果有前端构建)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 操作系统
Thumbs.db
.DS_Store
*.DS_Store